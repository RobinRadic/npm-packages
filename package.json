{
    "name": "radic",
    "version": "1.0.0",
    "description": "mono",
    "private": true,
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "nohoist": [
            "**/supermenu/font-awesome",
            "**/supermenu/font-awesome/**"
        ]
    },
    "resolutions2": {
        "before-after-hook": "1.4."
    },
    "scripts": {
        "apis": "cd packages/apis && yarn",
        "arrays": "cd packages/arrays && yarn",
        "bitbucket": "cd packages/bitbucket && yarn",
        "bithub": "cd packages/bithub && yarn",
        "console-colors": "cd packages/console-colors && yarn",
        "console-input": "cd packages/console-input && yarn",
        "console-output": "cd packages/console-output && yarn",
        "homey-server": "cd packages/homey-server && yarn",
        "homey": "cd packages/homey-server && yarn",
        "hoster": "cd packages/hoster && yarn",
        "collections": "cd packages/collections && yarn",
        "idea": "cd packages/idea && yarn",
        "observable": "cd packages/observable && yarn",
        "publisher": "cd packages/publisher && yarn",
        "supermenu": "cd packages/supermenu && yarn",
        "reset-evals": "cd packages/reset-evals && yarn",
        "tree": "cd packages/tree && yarn",
        "idea-sync": "cd packages/idea-sync && yarn",
        "util": "cd packages/util && yarn",
        "sites": "cd packages/sites && yarn",
        "utils": "cd packages/utils && yarn",
        "webpacker": "cd packages/webpacker && yarn",
        "publish:webpacker": "cd packages/webpacker && npm publish",
        "app:dev": "cd apps/dev && yarn",
        "app:node": "cd apps/node && yarn",
        "build": "concurrently \"yarn utils build\" \"yarn arrays build\"",
        "watch": "yarn build && concurrently \"yarn watch:tools\" \"yarn watch:util\"",
        "reinstall": "yarn clean:yarn && yarn && yarn build",
        "clean:build": "rimraf **/.nyc_output",
        "clean:yarn": "rimraf \"**/node_modules\" \"**/yarn.lock\" \"**/.nyc_ou*\""
    },
    "dependencies": {
        "@types/adm-zip": "^0.4.32",
        "@types/bootstrap": "^4.3.1",
        "@types/chai": "^4.2.2",
        "@types/classnames": "^2.2.9",
        "@types/cross-spawn": "^6.0.0",
        "@types/debug": "^4.1.5",
        "@types/dotenv": "^6.1.1",
