{
    "name": "radic",
    "version": "1.0.0",
    "description": "mono",
    "private": true,
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "nohoist": [

        ]
    },
    "scripts": {
        "util": "cd packages/util && yarn",
        "watch:util": "yarn util watch",
        "build:util": "yarn util build",
        "supermenu": "cd packages/supermenu && yarn",
        "watch:supermenu": "yarn tools watch",
        "build:supermenu": "yarn tools watch",
        "tree": "cd packages/tree && yarn",
        "webpacker": "cd packages/webpacker && yarn",
        "app:dev": "cd apps/dev && yarn",
        "build": "npm-run-all \"tools build\" \"util build\"",
        "watch": "yarn build && concurrently \"yarn watch:tools\" \"yarn watch:util\"",
        "reinstall": "rm -rf node_modules */node_modules yarn.lock */yarn.lock"
    },
    "dependencies": {
    },
    "devDependencies": {
        "@types/cross-spawn": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/inquirer": "^6.5.0",
        "webpack-cli": "^3.3.5",
        "concurrently": "^4.1.1",
        "ts-node": "^8.3.0",
        "typescript": "^3.5.3",
        "@types/lodash": "^4.14.138",
        "@types/node": "^12.6.9",
        "np": "^5.0.3",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "lodash": "^4.0",
        "release-it": "^12.3.5",
        "@types/lz-string": "^1.3.33"
    }
}
