{
    "name": "radic",
    "version": "1.0.0",
    "description": "mono",
    "private": true,
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "nohoist": [
            "@radic/supermenu/@types"
        ]
    },
    "scripts": {
        "publisher": "cd packages/publisher && yarn",
        "watch:publisher": "yarn publisher watch",
        "build:publisher": "yarn publisher build",
        "observable": "cd packages/observable && yarn",
        "watch:observable": "yarn observable watch",
        "build:observable": "yarn observable build",
        "bitbucket": "cd packages/bitbucket && yarn",
        "util": "cd packages/util && yarn",
        "watch:util": "yarn util watch",
        "build:util": "yarn util build",
        "supermenu": "cd packages/supermenu && yarn",
        "watch:supermenu": "yarn tools watch",
        "build:supermenu": "yarn tools watch",
        "tree": "cd packages/tree && yarn",
        "webpacker": "cd packages/webpacker && yarn",
        "app:dev": "cd apps/dev && yarn",
        "build": "npm-run-all \"tools build\" \"util build\"",
        "watch": "yarn build && concurrently \"yarn watch:tools\" \"yarn watch:util\"",
        "reinstall": "yarn clean:yarn && yarn build",
        "clean:build": "rimraf **/.nyc_output",
        "clean:yarn": "rimraf **/node_modules **/yarn.lock **/.nyc_ou"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/cross-spawn": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/inquirer": "^6.5.0",
        "@types/lodash": "^4.14.138",
        "@types/lz-string": "^1.3.33",
        "@types/node": "^12.6.9",
        "concurrently": "^4.1.1",
        "lodash": "^4.0",
        "np": "^5.0.3",
        "rimraf": "^3.0.0",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "release-it": "^12.3.5",
        "ts-node": "^8.3.0",
        "typescript": "^3.5.3",
        "webpack-cli": "^3.3.5",
        "webpackbar": "^4.0.0",
        "webpack": "^4.40.2",
        "webpack-dev-server": "^3.8.0",
        "sinon": "^7.4.2",
        "@types/sinon": "^7.0.13",
        "tap-nyc": "^1.0.3",
        "chai": "^4.2.0",
        "@types/chai": "^4.2.2",
        "nyc": "^14.1.1",
        "mocha": "^6.2.0",
        "@types/mocha": "^5.2.7",
        "mocha-typescript": "^1.1.17",
        "sinon-chai": "^3.3.0",
        "chai-sinon": "^2.8.1",
        "@types/sinon-chai": "^3.2.3"
    }
}
