    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "start": "yarn install && lerna bootstrap && yarn links && yarn build && yarn test",
        "clean": "yarn clean:build && yarn clean:lerna && yarn clean:modules",
        "clean:lerna": "lerna clean --yes",
        "clean:build": "gulp clean",
        "clean:modules": "rimraf node_modules/ *.log docs/ .tmp/",
        "build": "gulp build",
        "poststart": "chmod +x packages/cli/bin/r.js",
        "docs": "gulp docs",
        "docs:serve": "gulp docs:serve",
        "docs:deploy": "gulp docs:deploy",
        "watch": "gulp watch",
        "scan": "nsp check .",
        "test": "gulp test",
        "restart": "yarn stop && yarn start",
        "stop": "yarn clean",
        "links": "scripts/yworkspace each link; lerna link --force-local",
        "lerna": "lerna-wizard"
    },
