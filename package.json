        "@types/sinon-chai": "^3.2.3",
        "@types/superagent": "^4.1.3",
        "@types/yargs": "^13.0.2",
        "@vue/babel-preset-app": "^4.0.5",
        "adm-zip": "^0.4.13",
        "chai": "^4.2.0",
        "chai-sinon": "^2.8.1",
        "concurrently": "^4.1.1",
        "debug": "^4.1.1",
        "lodash": "^4.0",
        "mocha": "^6.2.0",
        "mocha-typescript": "^1.1.17",
        "np": "^5.0.3",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "nyc": "^14.1.1",
