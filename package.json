        "typescript-lit-html-plugin": "^0.9.0",
        "webpack": "^4.40.2",
        "webpack-cli": "^3.3.5",
        "webpack-dev-server": "^3.8.0",
        "webpackbar": "^4.0.0",
        "@radic/roller": "^1.0.0",
        "@babel/core": "^7.7.7",
        "gulp": "^4.0.2",
        "gulp-util": "^3.0.8",
        "gulpclass": "^0.2.0",
        "gulp-typescript": "^5.0.1",
        "gulp-rollup": "^2.16.2",
        "del": "^5.1.0",
        "@types/gulp": "^4.0.6",
        "@types/gulp-util": "^3.0.34",
        "@types/del": "^4.0.0",
        "rollup": "^1.28.0",
