{
    "name": "radic",
    "version": "1.0.0",
    "description": "mono",
    "private": true,
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "nohoist": [
            "@radic/supermenu/@types"
        ]
    },
    "scripts": {
        "bitbucket": "cd packages/bitbucket && yarn",
        "bithub": "cd packages/bithub && yarn",
        "collections": "cd packages/collections && yarn",
        "idea": "cd packages/idea && yarn",
        "observable": "cd packages/observable && yarn",
        "publisher": "cd packages/publisher && yarn",
        "supermenu": "cd packages/supermenu && yarn",
        "tree": "cd packages/tree && yarn",
        "util": "cd packages/util && yarn",
        "utils": "cd packages/utils && yarn",
        "webpacker": "cd packages/webpacker && yarn",
        "app:dev": "cd apps/dev && yarn",
        "app:node": "cd apps/node && yarn",
        "build": "npm-run-all \"tools build\" \"util build\"",
        "watch": "yarn build && concurrently \"yarn watch:tools\" \"yarn watch:util\"",
        "reinstall": "yarn clean:yarn && yarn build",
        "clean:build": "rimraf **/.nyc_output",
        "clean:yarn": "rimraf \"**/node_modules\" \"**/yarn.lock\" \"**/.nyc_ou*\""
    },
    "dependencies": {
        "@types/chai": "^4.2.2",
        "@types/cross-spawn": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/inquirer": "^6.5.0",
        "@types/lodash": "^4.14.138",
        "@types/lz-string": "^1.3.33",
        "@types/mocha": "^5.2.7",
        "@types/node": "^12.6.9",
        "@types/sinon": "^7.0.13",
        "@types/sinon-chai": "^3.2.3",
        "@types/yargs": "^13.0.2",
        "chai": "^4.2.0",
        "chai-sinon": "^2.8.1",
        "concurrently": "^4.1.1",
        "lodash": "^4.0",
        "mocha": "^6.2.0",
        "mocha-typescript": "^1.1.17",
        "np": "^5.0.3",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "nyc": "^14.1.1",
        "release-it": "^12.3.5",
        "rimraf": "^3.0.0",
        "sinon": "^7.4.2",
        "sinon-chai": "^3.3.0",
        "tap-nyc": "^1.0.3",
        "ts-node": "^8.3.0",
        "typescript": "^3.5.3",
        "webpack": "^4.40.2",
        "webpack-cli": "^3.3.5",
        "webpack-dev-server": "^3.8.0",
        "webpackbar": "^4.0.0"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.4.32",
        "@types/debug": "^4.1.5",
        "@types/superagent": "^4.1.3",
        "@types/zepto": "^1.0.30",
        "adm-zip": "^0.4.13",
        "debug": "^4.1.1",
        "superagent": "^5.1.0",
        "swagger-ts-generator": "^1.1.59",
        "typescript-lit-html-plugin": "^0.9.0"
    }
}
