{
    "name": "@radic/lnav-creator",
    "version": "0.1.4",
    "description": "Lnav log string creator",
    "main": "index.js",
    "types": "index.d.ts",
    "author": "Robin Radic <rradic@hotmail.com> (https://radic.nl/)",
    "license": "MIT",
    "repository": "https://github.com/robinradic/npm-packages",
    "homepage": "http://robin.radic.nl/npm-packages/lnav-creator",
    "scripts": {
        "clean": "rimraf types .nyc_output ./**/*.js",
        "test": "nyc mocha",
        "watch": "mocha-typescript-watch"
    },
    "bin": {
        "lnav-creator": "bin/lnav-creator.js"
    },
    "dependencies": {
        "globule": "^1.2.0",
        "inquirer": "^4.0.0",
        "lodash": "^4.15.0"
    },
    "radic": {
        "typedoc": {
            "module": "commonjs",
            "mode": "file",
            "target": "es6",
            "hideGenerator": false,
            "json": "docs/@radic-lnav-creator/typedoc.json",
            "verbose": true,
            "out": "docs/@radic-lnav-creator",
            "includeDeclarations": false,
            "excludeExternals": true,
            "ignoreCompilerErrors": true,
            "includes": "/mnt/fat/node/@radic/scripts/templates/typedoc/inc",
            "theme": "/mnt/fat/node/@radic/scripts/templates/typedoc/theme",
            "plugins": [
                "typedoc-plantuml"
            ],
            "exclude": "types,test"
        }
    },
    "bugs": {
        "email": "rradic@hotmail.com",
        "url": "https://github.com/robinradic/npm-packages/issues"
    },
    "devDependencies": {
        "source-map-support": "^0.5.0"
    }
}
