{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "outDir": "./",
        "declarationDir": "./",
        "typeRoots": [
            "../../node_modules/@types"
        ],
        "baseUrl": "./",
        "paths": {
            "@radic/util": ["../util/types"]
        }
    },
    "include": [
        "./src",
        "./src/**/*.d.ts"
    ],
    "exclude": [
        "./node_modules",
        "./types",
        "./es",
        "./lib",
        "./*.ts",
        "*.js"
    ],
    "compileOnSave": true
}
