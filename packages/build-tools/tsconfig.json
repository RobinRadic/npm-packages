{
    "compilerOptions": {
        "target": "es6",
        "lib": ["es2017", "dom"],
        "moduleResolution": "node",
        "module": "commonjs",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "inlineSourceMap": true,
        "allowJs": false,
        "inlineSources": true,
        "declaration": true,
        "pretty": true,
        "noImplicitAny": false,
        "noImplicitReturns": false,
        "allowUnreachableCode": true,
        "allowSyntheticDefaultImports": true,
        "outDir": "./",
        "declarationDir": "./",
        "typeRoots": [
            "./node_modules/@types",
            "./src/typings"
        ],
        "baseUrl": ".",
        "paths": {
            "@radic/console-colors": ["../console-colors/types/index.d.ts"],
            "@radic/console-colors/*": ["../console-colors/types/*"]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "./node_modules",
        "./types",
        "./types/*.d.ts",
        "./es",
        "./lib",
        "./umd",
        "./*.ts",
        "./*.d.ts",
        "*.js"
    ],
    "compileOnSave": true
}
