{
    "name": "@radic/build-tools",
    "version": "0.2.0",
    "description": "build tools",
    "main": "index.js",
    "keywords": [
        "util"
    ],
    "jsnext:main": "index.js",
    "module": "index.js",
    "types": "index.d.ts",
    "author": {
        "name": "Robin Radic",
        "email": "rradic@hotmail.com",
        "url": "https://radic.nl"
    },
    "license": "MIT",
    "files": [
        "index.js",
        "index.d.ts",
        "*.d.ts",
        "**/*.d.ts",
        "*.js",
        "**/*.js"
    ],
    "repository": "https://github.com/robinradic/build-tools",
    "homepage": "http://robin.radic.nl/npm-packages/build-tools",
    "bugs": {
        "email": "rradic@hotmail.com",
        "url": "https://github.com/robinradic/npm-packages/issues"
    },
    "scripts": {
        "test": "nyc mocha",
        "clean": "cp src/declarations.d.ts declarationsdts && rimraf types .nyc_output ./**/*.js ./lib *.d.ts *.js src/*.d.ts src/*.js && cp declarationsdts src/declarations.d.ts && rm declarationsdts",
        "watch": "mocha-typescript-watch"
    },
    "dependencies": {
        "lodash": "^4.17.4"
    },
    "devDependencies": {
        "source-map-support": "^0.5.0"
    },
    "radic": {
        "es": true,
        "docgen": true,
        "typedoc": false
    }
}
