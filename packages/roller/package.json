{
    "name": "@radic/roller",
    "version": "1.0.0",
    "description": "Rollup roller",
    "private": false,
    "author": {
        "name": "Robin Radic"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "typings": "lib/index.d.ts",
    "scripts": {
        "start": "npm-run-all clean:build build",
        "test": "echo \"test not implemented\" && exit 0",
        "build": "tsc --project tsconfig.build.json",
        "watch": "tsc --project tsconfig.build.json --watch",
        "clean:build": "rm -rf lib",
        "postinstall": "rm -rf node_modules/@types",
        "clean:yarn": "rm yarn.lock node_modules/",
        "prepare": "npm-run-all clean:build build",
        "login": "yarn login",
        "release": "npm-run-all clean:build build login && np --yolo --no-yarn"
    },
    "dependencies": {
        "@babel/core": "^7.7.7",
        "rollup-plugin-babel": "*",
        "rollup-plugin-terser": "*",
        "rollup-plugin-vue": "*",
        "rollup-plugin-uglify": "*",
        "rollup-plugin-copy": "*",
        "rollup-plugin-cleanup": "*",
        "rollup-plugin-visualizer": "*",
        "rollup-plugin-sizes": "*",
        "rollup-pluginutils": "*",
        "rollup-plugin-node-resolve": "*",
        "rollup-plugin-commonjs": "*"
    },
    "devDependencies": {
        "@types/babel-core": "^6.25.6",
        "@types/cross-spawn": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/file-loader": "^4.2.0",
        "@types/friendly-errors-webpack-plugin": "^0.1.2",
        "@types/html-webpack-plugin": "^3.2.1",
        "@types/inquirer": "^6.5.0",
        "@types/lodash": "^4.14.136",
        "@types/mini-css-extract-plugin": "^0.8.0",
        "@types/morgan": "^1.7.36",
        "@types/node": "^12.6.9",
        "@types/node-sass": "^4.11.0",
        "@types/npm": "^2.0.30",
        "@types/optimize-css-assets-webpack-plugin": "^1.3.3",
        "@types/pug": "^2.0.4",
        "@types/stylus": "^0.48.31",
        "@types/terser-webpack-plugin": "^1.2.1",
        "@types/webpack": "^4.32.1",
        "@types/webpack-bundle-analyzer": "^2.13.2",
        "@types/webpack-dev-server": "^3.1.7",
        "@types/webpackbar": "^2.6.0",
        "clean-webpack-plugin": "^3.0.0",
        "np": "^5.0.3",
        "npm-gui": "^2.1.0",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "release-it": "^12.3.5",
        "strip-css-comments": "^4.1.0",
        "terser": "^4.1.3",
        "ts-node": "^8.3.0",
        "typescript": "^3.5.3",
        "@vue/component-compiler": "^4.2.0",
        "@vue/component-compiler-utils": "^3.1.0",
        "postcss": "^7.0.26",
        "vue-template-compiler": "^2.6.10",
        "webpack-cli": "^3.3.5"
    },
    "peerDependencies": {
        "rollup": "^1.28.0"
    },
    "optionalDependencies": {}
}
