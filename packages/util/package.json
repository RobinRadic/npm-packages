{
    "name": "@radic/util",
    "version": "2.8.0",
    "description": "Utilities for node / browser",
    "main": "index.js",
    "keywords": [
        "util"
    ],
    "jsnext:main": "es/index.js",
    "module": "es/index.js",
    "types": "index.d.ts",
    "author": "Robin Radic <rradic@hotmail.com> (https://radic.nl/)",
    "license": "MIT",
    "files": [
        "index.js",
        "index.d.ts",
        "types/**/*.d.ts",
        "lib/**/*.js",
        "umd/*.js",
        "es/**/*.js"
    ],
    "repository": "https://github.com/robinradic/npm-packages",
    "homepage": "http://robin.radic.nl/npm-packages/util",
    "bugs": {
        "email": "rradic@hotmail.com",
        "url": "https://github.com/robinradic/npm-packages/issues"
    },
    "scripts": {
        "test": "nyc mocha",
        "clean": "rimraf types .nyc_output ./**/*.js",
        "watch": "mocha-typescript-watch"
    },
    "dependencies": {
        "lodash": "^4.17.4"
    },
    "devDependencies": {
        "source-map-support": "^0.5.0"
    },
    "radic": {
        "es": true,
        "umd": true,
        "moduleName": "radic_util",
        "typedoc": {
            "module": "commonjs",
            "mode": "file",
            "target": "es6",
            "hideGenerator": false,
            "json": "docs/@radic-util/typedoc.json",
            "verbose": true,
            "out": "docs/@radic-util",
            "includeDeclarations": false,
            "excludeExternals": true,
            "ignoreCompilerErrors": true,
            "includes": "/mnt/fat/node/@radic/scripts/templates/typedoc/inc",
            "theme": "/mnt/fat/node/@radic/scripts/templates/typedoc/theme",
            "plugins": [
                "typedoc-plantuml"
            ],
            "exclude": "types,test"
        }
    }
}
