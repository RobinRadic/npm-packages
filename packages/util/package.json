{
    "name": "@radic/util",
    "version": "2.3.1",
    "description": "Utilities for node / browser",
    "main": "index.js",
    "types": "index.d.ts",
    "author": "Robin Radic <rradic@hotmail.com> (https://radic.nl/)",
    "license": "MIT",
    "repository": "https://github.com/robinradic/npm-packages",
    "homepage": "http://robin.radic.nl/npm-packages/util",
    "scripts": {
        "build": "tsc",
        "pretest": "tsc",
        "test": "nyc mocha",
        "posttest": "rimraf ./**/*.js",
        "clean": "rimraf types ./**/*.js",
        "watch": "mocha-typescript-watch"
    },
    "dependencies": {
        "lodash": "^4.15.0"
    },
    "radic": {
        "typedoc": {
            "module": "commonjs",
            "mode": "file",
            "target": "es6",
            "hideGenerator": false,
            "json": "docs/@radic-util/typedoc.json",
            "verbose": true,
            "out": "docs/@radic-util",
            "includeDeclarations": false,
            "excludeExternals": true,
            "ignoreCompilerErrors": true,
            "includes": "/mnt/fat/node/lerna-test-@radic/scripts/templates/typedoc/inc",
            "theme": "/mnt/fat/node/lerna-test-@radic/scripts/templates/typedoc/theme",
            "plugins": [
                "typedoc-plantuml"
            ],
            "exclude": "types,test"
        }
    },
    "bugs": {
        "email": "rradic@hotmail.com",
        "url": "https://github.com/robinradic/npm-packages/issues"
    }
}
