{
    "name": "@radic/console-output",
    "version": "1.2.0",
    "description": "Console output",
    "private": false,
    "author": {
        "name": "Robin Radic"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "typings": "lib/index.d.ts",
    "bin": {
        "sites": "./bin/run"
    },
    "scripts": {
        "start": "npm-run-all clean:build build",
        "test": "nyc mocha --opts test/mocha.opts",
        "build": "yarn clean:build && tsc --project tsconfig.build.json",
        "watch": "tsc --project tsconfig.build.json --watch",
        "clean:build": "rm -rf lib",
        "clean:yarn": "rm yarn.lock node_modules/",
        "prepare": "npm-run-all clean:build build",
        "prepublish": "npm-run-all clean:build build",
        "login": "yarn login",
        "release": "npm-run-all clean:build build login && commit \"upd console-output\" && np --yolo --no-yarn"
    },
    "dependencies": {
        "chalk": "^2.4.2",
        "cli-highlight": "^2.1.4",
        "cli-table3": "^0.5.1",
        "cli-truncate": "^1.1.0",
        "color-convert": "^2.0.0",
        "columnify": "^1.5.4",
        "d": "^1.0.0",
        "indent-string": "^3.2.0",
        "listr": "^0.14.3",
        "lodash": "^4.17.11",
        "memory-streams": "^0.1.3",
        "multispinner": "^0.2.1",
        "ora": "^3.4.0",
        "progress": "^2.0.3",
        "slice-ansi": "^2.1.0",
        "sparkly": "^5.0.0",
        "string-width": "^4.2.0",
        "strip-ansi": "^5.0.0",
        "supports-color": "^6.1.0",
        "term-size": "^1.2.0",
        "trucolor": "^1.0.0",
        "tslib": "^1.9.3",
        "widest-line": "^3.1.0",
        "wrap-ansi": "^4.0.0",
        "archy": "^1.0.0",
        "beeper": "^2.0.0",
        "cli-table2": "^0.2.0"
    },
    "optionalDependencies": {
        "node-notifier": "^7.0.1"
    },
    "devDependencies": {
        "@types/ansi": "^0.3.2",
        "@types/chalk": "^2.2.0",
        "@types/cli-truncate": "^1.1.0",
        "@types/color-convert": "^1.9.0",
        "@types/d": "^1.0.0",
        "@types/indent-string": "^3.2.0",
        "@types/listr": "^0.14.2",
        "@types/ora": "^3.2.0",
        "@types/progress": "^2.0.3",
        "@types/slice-ansi": "^2.0.0",
        "@types/sparkly": "^5.0.0",
        "@types/strip-ansi": "^3.0.0",
        "@types/supports-color": "^5.3.0",
        "@types/term-size": "^1.2.0",
        "@types/wrap-ansi": "^3.0.0",
        "@types/archy": "^0.0.31",
        "@types/beeper": "^2.0.0",
        "@types/cli-table2": "^0.2.2",
        "@types/node-notifier": "^6.0.1"
    },
    "engines": {
        "node": ">=8.0.0"
    },
    "files": [
        "/bin",
        "/lib",
        "/npm-shrinkwrap.json",
        "/oclif.manifest.json"
    ],
    "oclif": {
        "commands": "./lib/cli/commands",
        "bin": "sites",
        "plugins": [
            "@oclif/plugin-help"
        ]
    }
}
