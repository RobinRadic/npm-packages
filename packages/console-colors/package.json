{
    "name": "@radic/console-colors",
    "version": "2.0.4",
    "description": "Console Colors text parser. Apply colors to texts fast & easy. Use hex/rgb colors with auto (or custom) fallback for unsupported terminals.",
    "main": "index.js",
    "types": "index.d.ts",
    "author": "Robin Radic <rradic@hotmail.com> (https://radic.nl/)",
    "license": "MIT",
    "repository": "https://github.com/robinradic/npm-packages",
    "homepage": "http://robin.radic.nl/npm-packages/console-colors",
    "scripts": {
        "test": "nyc mocha",
        "watch": "mocha-typescript-watch",
        "clean": "rimraf types .nyc_output ./**/*.js"
    },
    "radic": {
        "typedoc": {
            "module": "commonjs",
            "mode": "file",
            "target": "es6",
            "hideGenerator": false,
            "json": "docs/@radic-console-colors/typedoc.json",
            "verbose": true,
            "out": "docs/@radic-console-colors",
            "includeDeclarations": false,
            "excludeExternals": true,
            "ignoreCompilerErrors": true,
            "includes": "/mnt/fat/node/@radic/scripts/templates/typedoc/inc",
            "theme": "/mnt/fat/node/@radic/scripts/templates/typedoc/theme",
            "plugins": [
                "typedoc-plantuml"
            ],
            "exclude": "types,test",
            "readme": "/mnt/fat/node/lerna-test-@radic/packages/console-colors/README.md",
            "name": "Console Colors"
        }
    },
    "dependencies": {
        "color-convert": "^1.5.0",
        "lodash": "^4.15.0",
        "supports-color": "^3.1.2",
        "trucolor": "^0.6.6"
    },
    "bugs": {
        "email": "rradic@hotmail.com",
        "url": "https://github.com/robinradic/npm-packages/issues"
    },
    "devDependencies": {
        "source-map-support": "^0.5.0"
    }
}
