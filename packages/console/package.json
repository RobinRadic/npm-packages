{
    "name": "@radic/console",
    "version": "0.0.19",
    "description": "Console library",
    "main": "index.js",
    "author": "Robin Radic",
    "license": "MIT",
    "types": "types",
    "homepage": "https://robin.radic.nl/npm-packages",
    "repository": "https://github.com/robinradic/npm-packages",
    "bin": "examples/r.js",
    "scripts": {
        "build": "tsc",
        "pretest": "tsc",
        "test": "nyc mocha",
        "posttest": "rimraf test/*.js",
        "clean": "rimraf types ./**/*.js",
        "watch": "mocha-typescript-watch",
        "prepare": "tsc"
    },
    "scriptsw": {
        "link": "npm link @radic/console-colors && npm link @radic/util",
        "reinstall": "rm -rf node_modules yarn.lock package-lock.json && yarn install",
        "start": "npm run reinstall && npm run link && npm run build && npm run watch",
        "build": "gulp build",
        "watch": "gulp watch",
        "pretest": "gulp build:test",
        "test": "nyc mocha",
        "posttest": "nyc report --reporter=json && codecov -f coverage/*.json",
        "clean": "gulp clean",
        "docs": "npm run docs:generate && npm run docs:serve",
        "docs:generate": "rm -r docs &> /dev/null ; typedoc --name \"Radical Console\" --readme docs.md --target ES6 --exclude spec example example2 node_modules types/lodash --ignoreCompilerErrors --mode file --excludeNotExported --excludePrivate --out docs ./dts/index.d.ts",
        "docs:serve": "cd docs && lite-server",
        "docs:deploy": "npm run docs:generate; gulp ghpages",
        "preversion": "npm test",
        "version": "npm run build && git add -A",
        "postversion": "git push && git push --tags  && npm run docs:deploy"
    },
    "dependencies": {
        "@radic/console-colors": "^2.0.0",
        "@radic/util": "^2.2.0",
        "archy": "^1.0.0",
        "async": "^2.4.0",
        "axios": "^0.16.1",
        "beeper": "^1.1.1",
        "callsites": "^2.0.0",
        "cli-highlight": "^1.1.4",
        "cli-spinner": "^0.2.6",
        "cli-spinners": "^1.0.0",
        "cli-table2": "^0.2.0",
        "cli-truncate": "^1.1.0",
        "columnify": "latest",
        "cryptr": "^2.0.0",
        "dotenv": "^4.0.0",
        "env-paths": "^1.0.0",
        "eventemitter2": "^4.0.0",
        "fs-extra": "^3.0.1",
        "globule": "^1.1.0",
        "inquirer": "^3.0.6",
        "inquirer-autocomplete-prompt": "^0.11.0",
        "inquirer-datepicker-prompt": "DerekTBrown/inquirer-datepicker-prompt#master",
        "inversify": "^4.5.1",
        "inversify-binding-decorators": "^3.0.0",
        "inversify-inject-decorators": "^3.0.2",
        "inversify-vanillajs-helpers": "^2.0.0",
        "lodash": "^4.17.4",
        "moment": "^2.18.1",
        "multispinner": "^0.2.1",
        "node-notifier": "^5.1.2",
        "node-progress-3": "^0.4.3",
        "ora": "^1.3.0",
        "reflect-metadata": "^0.1.10",
        "shelljs": "^0.7.7",
        "sleep": "^5.1.1",
        "slice-ansi": "^1.0.0",
        "sparkly": "^3.1.2",
        "string": "^3.3.3",
        "string-width": "^2.1.1",
        "tabtab": "^2.2.2",
        "through2": "^2.0.3",
        "through2-filter": "^2.0.0",
        "tmp": "^0.0.31",
        "truwrap": "^0.7.4",
        "typescript": "^2.4.1",
        "validatorjs": "^3.12.0",
        "vinyl": "^2.1.0",
        "vinyl-buffer": "^1.0.0",
        "vinyl-fs": "^2.4.4",
        "vinyl-paths": "^2.1.0",
        "vinyl-source-stream": "^1.1.0",
        "widest-line": "^1.0.0",
        "winston": "^2.3.1",
        "wrap-ansi": "^3.0.1",
        "yargs-parser": "^5.0.0"
    }
}
