{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "outDir": "./",
        "declarationDir": "./types",
        "typeRoots": [
            "./node_modules/@types",
            "./src/typings"
        ],
        "baseUrl": ".",
        "paths": {
            "@radic/build-tools": ["../build-tools/types"],
            "@radic/build-tools/*": ["../build-tools/types/*"]
        }
    },
    "include": [
        "./src",
        "./src/**/*.d.ts"
    ],
    "exclude": [
        "./node_modules",
        "./types",
        "./*.ts",
        "*.js"
    ],
    "compileOnSave": true
}
