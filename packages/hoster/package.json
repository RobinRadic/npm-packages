{
    "name": "@radic/hoster",
    "version": "1.0.0",
    "description": "Hoster",
    "private": false,
    "author": {
        "name": "Robin Radic"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "typings": "lib/index.d.ts",
    "bin": {
        "hoster": "./bin/run"
    },
    "scripts": {
        "start": "npm-run-all clean:build build",
        "build": "tsc --project tsconfig.build.json",
        "watch": "tsc --project tsconfig.build.json --watch",
        "clean:build": "rm -rf lib",
        "clean:yarn": "rm yarn.lock node_modules/",
        "prepare": "npm-run-all clean:build build",
        "postpublish": "git pull",
        "postpack": "rm -f oclif.manifest.json",
        "prepack": "rm -rf lib && tsc -b && oclif-dev manifest && oclif-dev readme",
        "test": "nyc --extension .ts mocha --forbid-only \"test/**/*.test.ts\"",
        "version": "oclif-dev readme && git add README.md",
        "login": "yarn login",
        "release": "npm-run-all clean:build build login && np --yolo --no-yarn"
    },
    "dependencies": {
        "@oclif/command": "^1",
        "@oclif/config": "^1",
        "@oclif/plugin-commands": "^1.2.3",
        "@oclif/plugin-help": "^2",
        "@oclif/plugin-not-found": "^1.2.3",
        "@oclif/plugin-update": "^1.3.9",
        "@oclif/plugin-warn-if-update-available": "^1.7.0",
        "@types/chalk": "^2.2.0",
        "@types/sprintf-js": "^1.1.2",
        "@yarnpkg/lockfile": "^1.1.0",
        "@radic/console-input": "^1.1.0",
        "@radic/console-output": "^1.2.0",
        "chalk": "^3.0.0",
        "cross-spawn": "^6.0.5",
        "dotenv": "^8.0.0",
        "reflect-metadata": "^0.1.13",
        "inquirer": "^6.5.0",
        "inquirer-directory": "^2.2.0",
        "inquirer-fuzzy-path": "^2.2.0",
        "lodash": "^4.17.15",
        "nginx-conf": "^1.5.0",
        "npm": "^6.10.2",
        "semver": "^6.3.0",
        "sprintf-js": "^1.1.2",
        "yargs": "^14.0.0",
        "conf": "^6.2.4",
        "glob": "^7.1.6",
        "tonto": "^0.1.1",
        "apacheconf": "^0.0.5"
    },
    "devDependencies": {
        "@types/cross-spawn": "^6.0.0",
        "@types/dotenv": "^6.1.1",
        "@types/inquirer": "^6.5.0",
        "@types/lodash": "^4.14.136",
        "@types/node": "^12.6.9",
        "@types/npm": "^2.0.30",
        "@types/semver": "^6.0.2",
        "@types/yargs": "^13.0.2",
        "@types/glob": "^7.1.1",
        "npm-run-all": "^4.1.5",
        "nps": "^5.9.5",
        "nps-utils": "^1.7.0",
        "ts-node": "^8.3.0",
        "typescript": "^3.5.3"
    },
    "engines": {
        "node": ">=8.0.0"
    },
    "files": [
        "/bin",
        "/lib",
        "/npm-shrinkwrap.json",
        "/oclif.manifest.json"
    ],
    "oclif": {
        "commands": "./lib/commands",
        "bin": "hoster",
        "plugins": [
            "@oclif/plugin-help"
        ]
    }
}
