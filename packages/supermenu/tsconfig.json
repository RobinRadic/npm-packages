{
    "compileOnSave": false,
    "compilerOptions": {
        "allowUnreachableCode": true,
        "declaration": false,
        "lib": [
            "dom",
            "es2017"
        ],
        "moduleResolution": "node",
        "module": "esnext",
        "target": "es2017",
        "jsx": "react",
        "jsxFactory": "h",
        "baseUrl": ".",
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "strictFunctionTypes": false,
        "strictBindCallApply": false,
        "strictPropertyInitialization": false,
        "noImplicitThis": false,
        "alwaysStrict": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noImplicitReturns": false,
        "noFallthroughCasesInSwitch": false,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "inlineSourceMap": false,
        "inlineSources": false,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "paths": {
            "@/*": ["src/*"],
            "@menu": ["src/components/supermenu/menu/menu.tsx"],
            "@menu-item": ["src/components/supermenu/menu-item/menu-item.tsx"],
            "@menu-submenu": ["src/components/supermenu/menu-submenu/menu-submenu.tsx"],
            "#": ["src/utils/index.ts"],
            "#/*": ["src/utils/*"],
            "#/tunnels": ["src/utils/tunnels.tsx"]
        }
    },
    "include": [
        "src",
        "types/jsx.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
