mixin menu-item(title, icon)
    - icon = icon ? 'fa fa-' + icon : icon;
    li.sm-item&attributes(attributes)
        a.sm-item__content.sm-item__item-content--link(href="#")
            span.sm-item__icon
                if icon
                    i(class=icon)
            span.sm-item__title=title
            span.sm-item__arrow: i
        block

mixin menu()
    ul&attributes(attributes)
        +menu-item('Dashboard', 'dashboard')
        +menu-item('Account', 'user')
        +menu-item('Settings', 'cogs').has-children.is-open.is-focused
            ul.sm-item__submenu
                +menu-item('Title 2.1', 'windows')
                +menu-item('Title 2.2', 'wifi').has-children.is-focused
                    ul.sm-item__submenu
                        +menu-item('Title 2.2.1', 'usb').is-focused.is-selected
                        +menu-item('Title 2.2.2')
                +menu-item('Title 2.3', 'upload')
                +menu-item('Title 2.4')
                    ul.sm-item__submenu
                        +menu-item('Title 2.1', 'windows')
                        +menu-item('Title 2.2', 'wifi').has-children.is-focused
                            ul.sm-item__submenu
                                +menu-item('Title 2.2.1', 'usb').is-focused.is-selected
                                +menu-item('Title 2.2.2')
                        +menu-item('Title 2.3', 'upload')
                        +menu-item('Title 2.4')
                        +menu-item('Title 2.5', 'unlock-alt')
                +menu-item('Title 2.5', 'unlock-alt')
        +menu-item('Database', 'database')
        +menu-item('Users', 'users').has-children
            ul.sm-item__submenu
                +menu-item('Users')
                +menu-item('Roles')
        +menu-item('Pages', 'file-code-o').has-submenu-up
            ul.sm-item__submenu
                +menu-item('Title 2.1', 'windows')
                +menu-item('Title 2.2', 'wifi').has-children.is-focused.has-submenu-right
                    ul.sm-item__submenu
                        +menu-item('Title 2.2.1', 'usb').is-focused.is-selected
                        +menu-item('Title 2.2.2')
                +menu-item('Title 2.3', 'upload')
                +menu-item('Title 2.4').has-submenu-right
                    ul.sm-item__submenu
                        +menu-item('Title 2.1', 'windows')
                        +menu-item('Title 2.2', 'wifi').has-children.is-focused
                            ul.sm-item__submenu
                                +menu-item('Title 2.2.1', 'usb').is-focused.is-selected
                                +menu-item('Title 2.2.2')
                        +menu-item('Title 2.3', 'upload')
                        +menu-item('Title 2.4')
                        +menu-item('Title 2.5', 'unlock-alt')
                +menu-item('Title 2.5', 'unlock-alt')
        +menu-item('Post', 'envelope-o')
        +menu-item('System', 'flash')

doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        title Title
        script(src="https://cdnjs.cloudflare.com/ajax/libs/webcomponentsjs/2.2.10/custom-elements-es5-adapter.js")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/webcomponentsjs/2.2.10/webcomponents-loader.js")
    body
        .layout
            .layout__header headf
            .layout__side.layout__side--left
            .layout__side.layout__side--right right
            .layout__content
                .row.m-3.demo-sm-section
                    .demo-sm-content.col-12
                        h3 horizontal + dropdown
                        +menu.sm.sm--horizontal.sm--dropdown



                .row.m-3.demo-sm-section
                    .demo-sm-content.col-3.m-1
                        h3
                            | inline
                            small.float-right
                                a(data-menu-action="get" data-menu-action-params='["2.1.1"]' href="javascript: void(0);") open 2.1.1
                        +menu.sm.sm--inline
                    .demo-sm-content.col-3.m-1
                        h3 collapsed + dropdown
                        +menu(style="width: 50px; background: #333333").sm.sm--collapsed.sm--dropdown
                    .demo-sm-content.col-3.m-1


                .row.m-3.demo-sm-section
                    .demo-sm-content.col-12
                        h3 horizontal + dropdown
                        +menu.sm.sm--horizontal.sm--dropdown.sm--dropdown-up.sm--dropdown-right



    .layout__footer foot

    script.
        var $menu = demo.init('.sm')
